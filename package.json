{
  "name": "whichmodel-mcp",
  "version": "1.1.0",
  "description": "MCP server that provides cost-optimised model recommendations for autonomous agents",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "whichmodel-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "seed": "tsx src/pipeline/seed.ts",
    "update-prices": "tsx src/pipeline/update.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.49.4",
    "express": "^5.1.0",
    "grammy": "^1.42.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260410.1",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.80.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "pricing",
    "model-selection",
    "autonomous-agents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Which-Model/whichmodel-mcp.git"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
